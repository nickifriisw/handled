# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL from: supabase.com → your project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
# "anon public" key (safe for client, restricted by RLS)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# "service_role" key (NEVER expose publicly — bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Twilio ───────────────────────────────────────────────────────────────────
# console.twilio.com → Account → API keys & tokens
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Your Twilio phone number in E.164 format — used as fallback/default
TWILIO_FROM_NUMBER=+447700000000
# SID of the Twilio number (found in Console → Phone Numbers → Active numbers)
# Required by `npm run setup-webhooks` to configure SMS/voice callbacks
TWILIO_PHONE_SID=PNxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Anthropic ────────────────────────────────────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Stripe ───────────────────────────────────────────────────────────────────
# dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
# Webhooks → Add endpoint → copy signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# dashboard.stripe.com → Products → create "HANDLED Monthly" → copy price ID
STRIPE_PRICE_ID_MONTHLY=price_...
# dashboard.stripe.com → Products → create "HANDLED Annual" → copy price ID
STRIPE_PRICE_ID_ANNUAL=price_...

# ─── Loops.so (email) ─────────────────────────────────────────────────────────
# app.loops.so → Settings → API Key
LOOPS_API_KEY=...

# Transactional template IDs — Loops dashboard → Transactional → your template → copy ID from URL
# e.g. https://app.loops.so/transactional/edit/clxxxxxxxxxx  →  LOOPS_TEMPLATE_WELCOME=clxxxxxxxxxx
LOOPS_TEMPLATE_WELCOME=
LOOPS_TEMPLATE_TRIAL_ENDING=
LOOPS_TEMPLATE_ACTIVATED=
LOOPS_TEMPLATE_PAYMENT_FAILED=
LOOPS_TEMPLATE_CANCELLED=
LOOPS_TEMPLATE_DAILY_DIGEST=

# ─── Optional config ──────────────────────────────────────────────────────────
# Number of days before a "sent" estimate auto-expires (default: 30)
ESTIMATE_EXPIRY_DAYS=30

# ─── Sentry (optional — error monitoring) ────────────────────────────────────
# sentry.io → your project → Settings → Client Keys → DSN
# Leave blank to disable Sentry; the API runs normally without it.
SENTRY_DSN=

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Public URL of the deployed app (used for Twilio webhook URLs)
APP_URL=https://handled.railway.app
# Secret header value for the /cron/process-scheduled endpoint
CRON_SECRET=change-me-to-a-random-32-char-string
